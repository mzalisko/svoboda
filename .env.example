# Скопіювати в .env та заповнити реальними значеннями. .env НЕ комітиться (див. .gitignore).

DB_NAME=svoboda
DB_USER=svoboda
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# Секрети нижче використовуються лише для довідки при заповненні wp-config.php
# як PHP-констант (define('MONOBANK_TOKEN', '...')) — сам .env тут не читається
# WordPress-контейнером напряму, це навмисно (secrets server-side, не env у docker inspect).
MONOBANK_TOKEN=
NOVAPOSHTA_API_KEY=
