 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u0432\u0430\u0442\u0438\u0441\u044f \u043a\u0456\u043b\u044c\u043a\u043e\u043c\u0430 \u0441\u0442\u043e\u0440\u0456\u043d\u043a\u0430\u043c\u0438, \u0442\u043e\u043c\u0443 \u0431\u0443\u0434\u044c-\u044f\u043a\u0456 \u0437\u043c\u0456\u043d\u0438, \u0432\u043d\u0435\u0441\u0435\u043d\u0456 \u0442\u0443\u0442, \u043c\u043e\u0436\u0443\u0442\u044c \u0432\u043f\u043b\u0438\u043d\u0443\u0442\u0438 \u043d\u0430 \u0456\u043d\u0448\u0456 \u0441\u0442\u043e\u0440\u0456\u043d\u043a\u0438 \u0441\u0430\u0439\u0442\u0443. \u0429\u043e\u0431\u0438 \u043f\u043e\u0432\u0435\u0440\u043d\u0443\u0442\u0438\u0441\u044f \u043d\u0430\u0437\u0430\u0434 \u0434\u043e \u0440\u0435\u0434\u0430\u0433\u0443\u0432\u0430\u043d\u043d\u044f \u0432\u043c\u0456\u0441\u0442\u0443 \u0441\u0442\u043e\u0440\u0456\u043d\u043a\u0438, \u043d\u0430\u0442\u0438\u0441\u043d\u0456\u0442\u044c \u043a\u043d\u043e\u043f\u043a\u0443 \"\u041d\u0430\u0437\u0430\u0434\" \u043d\u0430 \u043f\u0430\u043d\u0435\u043b\u0456 \u0456\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u0456\u0432."],"Open style revisions":["\u0412\u0456\u0434\u043a\u0440\u0438\u0442\u0438 \u0440\u0435\u0434\u0430\u043a\u0446\u0456\u0457 \u0441\u0442\u0438\u043b\u0456\u0432"],"Editing a template":["\u0420\u0435\u0434\u0430\u0433\u0443\u0432\u0430\u043d\u043d\u044f \u0448\u0430\u0431\u043b\u043e\u043d\u0443"],"It\u2019s now possible to edit page content in the site editor. To customise other parts of the page like the header and footer switch to editing the template using the settings sidebar.":["\u0422\u0435\u043f\u0435\u0440 \u043c\u043e\u0436\u043b\u0438\u0432\u043e \u0440\u0435\u0434\u0430\u0433\u0443\u0432\u0430\u0442\u0438 \u0432\u043c\u0456\u0441\u0442 \u0441\u0442\u043e\u0440\u0456\u043d\u043a\u0438 \u0432 \u0440\u0435\u0434\u0430\u043a\u0442\u043e\u0440\u0456 \u0441\u0430\u0439\u0442\u0443. \u0429\u043e\u0431\u0438 \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u0442\u0438 \u0456\u043d\u0448\u0456 \u0447\u0430\u0441\u0442\u0438\u043d\u0438 \u0441\u0442\u043e\u0440\u0456\u043d\u043a\u0438, \u0442\u0430\u043a\u0456 \u044f\u043a \u0445\u0435\u0434\u0435\u0440 \u0456 \u0444\u0443\u0442\u0435\u0440, \u043f\u0435\u0440\u0435\u0439\u0434\u0456\u0442\u044c \u0434\u043e \u0440\u0435\u0434\u0430\u0433\u0443\u0432\u0430\u043d\u043d\u044f \u0448\u0430\u0431\u043b\u043e\u043d\u0443 \u0437\u0430 \u0434\u043e\u043f\u043e\u043c\u043e\u0433\u043e\u044e \u0431\u0456\u0447\u043d\u043e\u0457 \u043f\u0430\u043d\u0435\u043b\u0456 \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u044c."],"Continue":["\u041f\u0440\u043e\u0434\u043e\u0432\u0436\u0438\u0442\u0438"],"Create draft":["\u0421\u0442\u0432\u043e\u0440\u0438\u0442\u0438 \u0447\u0435\u0440\u043d\u0435\u0442\u043a\u0443"],"No title":["\u0411\u0435\u0437 \u0437\u0430\u0433\u043e\u043b\u043e\u0432\u043a\u0430"],"No Navigation Menus found.":["\u041c\u0435\u043d\u044e \u043d\u0430\u0432\u0456\u0433\u0430\u0446\u0456\u0457 \u043d\u0435 \u0437\u043d\u0430\u0439\u0434\u0435\u043d\u043e."],"Editing a page":["\u0420\u0435\u0434\u0430\u0433\u0443\u0432\u0430\u043d\u043d\u044f \u0441\u0442\u043e\u0440\u0456\u043d\u043a\u0438"],"Go to %s":["\u041f\u0435\u0440\u0435\u0439\u0442\u0438 \u0434\u043e %s"],"Review %d change\u2026":["\u041f\u0435\u0440\u0435\u0433\u043b\u044f\u043d\u0443\u0442\u0438 %d \u0437\u043c\u0456\u043d\u0443\u2026","\u041f\u0435\u0440\u0435\u0433\u043b\u044f\u043d\u0443\u0442\u0438 %d \u0437\u043c\u0456\u043d\u0438\u2026","\u041f\u0435\u0440\u0435\u0433\u043b\u044f\u043d\u0443\u0442\u0438 %d \u0437\u043c\u0456\u043d\u2026"],"Activate & Save":["\u0410\u043a\u0442\u0438\u0432\u0443\u0432\u0430\u0442\u0438 \u0442\u0430 \u0437\u0431\u0435\u0440\u0435\u0433\u0442\u0438"],"Navigation Menu missing.":["\u041c\u0435\u043d\u044e \u043d\u0430\u0432\u0456\u0433\u0430\u0446\u0456\u0457 \u0432\u0456\u0434\u0441\u0443\u0442\u043d\u0454."],"Manage the fonts and typography used on captions.":["\u041a\u0435\u0440\u0443\u0439\u0442\u0435 \u0448\u0440\u0438\u0444\u0442\u0430\u043c\u0438 \u0442\u0430 \u0442\u0438\u043f\u043e\u0433\u0440\u0430\u0444\u0456\u0454\u044e, \u044f\u043a\u0456 \u0432\u0438\u043a\u043e\u0440\u0438\u0441\u0442\u043e\u0432\u0443\u044e\u0442\u044c\u0441\u044f \u0432 \u043f\u0456\u0434\u0437\u0430\u0433\u043e\u043b\u043e\u0432\u043a\u0430\u0445."],"Manage what patterns are available when editing the site.":["\u041a\u0435\u0440\u0443\u0439\u0442\u0435 \u0442\u0438\u043c, \u044f\u043a\u0456 \u043f\u0430\u0442\u0435\u0440\u043d\u0438 \u0431\u0443\u0434\u0443\u0442\u044c \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u0438\u043c\u0438 \u043f\u0456\u0434 \u0447\u0430\u0441 \u0440\u0435\u0434\u0430\u0433\u0443\u0432\u0430\u043d\u043d\u044f \u0441\u0430\u0439\u0442\u0443."],"Navigation title":["\u0417\u0430\u0433\u043e\u043b\u043e\u0432\u043e\u043a \u043d\u0430\u0432\u0456\u0433\u0430\u0446\u0456\u0457"],"Manage your Navigation Menus.":["\u041a\u0435\u0440\u0443\u0439\u0442\u0435 \u0441\u0432\u043e\u0457\u043c\u0438 \u043c\u0435\u043d\u044e \u043d\u0430\u0432\u0456\u0433\u0430\u0446\u0456\u0457."],"Are you sure you want to delete this Navigation Menu?":["\u0412\u0438 \u0432\u043f\u0435\u0432\u043d\u0435\u043d\u0456, \u0449\u043e \u0445\u043e\u0447\u0435\u0442\u0435 \u0432\u0438\u0434\u0430\u043b\u0438\u0442\u0438 \u0446\u0435 \u043c\u0435\u043d\u044e \u043d\u0430\u0432\u0456\u0433\u0430\u0446\u0456\u0457?"],"Unable to delete Navigation Menu (%s).":["\u041d\u0435 \u0432\u0434\u0430\u043b\u043e\u0441\u044f \u0432\u0438\u0434\u0430\u043b\u0438\u0442\u0438 \u043c\u0435\u043d\u044e \u043d\u0430\u0432\u0456\u0433\u0430\u0446\u0456\u0457 (%s)."],"Renamed Navigation Menu":["\u041c\u0435\u043d\u044e \u043d\u0430\u0432\u0456\u0433\u0430\u0446\u0456\u0457 \u043f\u0435\u0440\u0435\u0439\u043c\u0435\u043d\u043e\u0432\u0430\u043d\u043e"],"Unable to rename Navigation Menu (%s).":["\u041d\u0435 \u0432\u0434\u0430\u043b\u043e\u0441\u044f \u043f\u0435\u0440\